{
  "name": "melmuk/luasandbox-wrapper",
  "description": "PHP wrapper around the luasandbox extension.",
  "type": "library",
  "license": "ISC",
  "authors": [
    {
      "name": "Martin Melmuk",
      "email": "martin.melmuk@outlook.com",
      "homepage": "https://melmuk.at"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-luasandbox": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Melmuk\\LuaSandboxWrapper\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Melmuk\\LuaSandboxWrapper\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=always"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
